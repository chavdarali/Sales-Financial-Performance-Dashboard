OUNT(*) AS Total_Calls
FROM Product_Sales;

SELECT SUM(ProductSold) AS Total_Sales
FROM Product_Sales;

SELECT
ROUND(
100.0 * SUM(ProductSold) / COUNT(*),
2
) AS Conversion_Rate_Percent
FROM Product_Sales;

SELECT
Agent_Name,
SUM(ProductSold) AS Sales
FROM Product_Sales
GROUP BY Agent_Name
ORDER BY Sales DESC;

SELECT
Agent_Name,
SUM(ProductSold) * 120 AS Revenue
FROM Product_Sales
GROUP BY Agent_Name
ORDER BY Revenue DESC;

SELECT
Agent_Name,
SUM(ProductSold) * 120 AS Revenue
FROM Product_Sales
GROUP BY Agent_Name
ORDER BY Revenue DESC
LIMIT 10;

SELECT
Agent_Name,
ROUND(AVG(Duration),2) AS Avg_Call_Duration
FROM Product_Sales
GROUP BY Agent_Name
ORDER BY Avg_Call_Duration DESC;

SELECT
Agent_Name,
SUM(ProductSold) * 120 AS Revenue,
SUM(Duration) AS Total_Minutes,
ROUND(
(SUM(ProductSold) * 120.0) /
SUM(Duration),
2
) AS Revenue_Per_Minute
FROM Product_Sales
GROUP BY Agent_Name
ORDER BY Revenue_Per_Minute DESC;

SELECT
COUNT(*) AS Missed_Calls
FROM Product_Sales
WHERE PickedUp = 0;

SELECT
Agent_Name,
COUNT(*) AS Calls,
SUM(ProductSold) AS Sales,
ROUND(AVG(Duration),2) AS Avg_Duration,
SUM(ProductSold) * 120 AS Revenue
FROM Product_Sales
GROUP BY Agent_Name
ORDER BY Revenue DESC;</sql><current_tab id="0"/></tab_sql></sqlb_project>
